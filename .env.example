# 复制此文件为 .env，填入你的 DeepSeek API Key（第 2/3 层对话功能需要）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# （可选）默认实验目录：lab / research-ops 不带 -w 时用它。
# 设成你平时放实验的目录，之后直接敲 lab 就能看当前实验。
# RESEARCHOPS_WORKSPACE=workspace
# RESEARCHOPS_WORKSPACE=examples/vision_token_compression

# （可选）默认推理模型：deepseek-chat（快）或 deepseek-reasoner（推理强）
# DEEPSEEK_MODEL=deepseek-chat
