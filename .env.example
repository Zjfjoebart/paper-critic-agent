# 复制此文件为 .env，填入你的 DeepSeek API Key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# （可选）论文库文件夹：设成你自己的路径后，paper-zjf 每次都自动扫这里，
# 不用再把论文搬进项目。支持 ~ 。不设则默认用项目下的 papers/。
# 例：
# PAPERS_DIR=~/Papers
# PAPERS_DIR=~/Downloads/论文

# （可选）默认推理模型：deepseek-chat（快/便宜）或 deepseek-reasoner（推理强）
# 会话中也可用 /model 临时切换。
# DEEPSEEK_MODEL=deepseek-chat
